{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibridge.dev/schemas/bridge.schema.json",
  "title": "AiBridge Config",
  "type": "object",
  "required": ["schemaVersion", "projectName", "createdAt", "agents"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "projectName": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "kind", "configPath"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "configPath": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
